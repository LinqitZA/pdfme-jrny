# pdfme ERP Edition — Environment Variables
# Copy this file to .env and adjust values as needed.

# NestJS API
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pdfme_erp
REDIS_HOST=localhost
REDIS_PORT=6379

# File storage root (absolute or relative to nest-module)
PDFME_STORAGE_ROOT=./storage

# Document hashing algorithm: sha256 | blake3
HASH_ALGORITHM=sha256

# Designer Sandbox (Next.js)
# Used by the designer to reach the API at runtime
NEXT_PUBLIC_API_BASE=http://localhost:3001/api/pdfme
