{
  "name": "@pdfme-erp/nest",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS integration module for pdfme ERP Edition — TemplateService, RenderService, DataSourceRegistry, FileStorageService, controllers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "jest",
    "lint": "eslint src/",
    "start": "node dist/main.js",
    "start:dev": "npx ts-node --project tsconfig.json src/main.ts",
    "migrate": "npx ts-node --project tsconfig.json src/db/migrate.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.0.0",
    "jsonwebtoken": "^9.0.0",
    "@paralleldrive/cuid2": "^2.2.0",
    "@pdfme-erp/schemas": "*",
    "@pdfme/common": "*",
    "@pdfme/generator": "*",
    "bullmq": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "blake3": "^2.1.4",
    "expr-eval-fork": "^3.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
